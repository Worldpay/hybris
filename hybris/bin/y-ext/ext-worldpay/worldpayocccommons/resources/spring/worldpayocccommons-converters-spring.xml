<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:schemaLocation="http://www.springframework.org/schema/beans http://www.springframework.org/schema/beans/spring-beans.xsd">

    <bean id="worldpayAddressWsDTOAddressDataPopulator"
          class="com.worldpay.worldpayocccommons.populators.WorldpayAddressWsDTOAddressDataPopulator">
        <constructor-arg name="i18NFacade" ref="i18NFacade"/>
        <constructor-arg name="checkoutCustomerStrategy" ref="checkoutCustomerStrategy"/>
    </bean>

    <bean id="httpRequestAddressWsDTOPopulator"
          class="com.worldpay.worldpayocccommons.populators.HttpRequestAddressWsDTOPopulator">
        <constructor-arg name="i18NFacade" ref="i18NFacade"/>
    </bean>

    <bean id="httpRequestPaymentDetailsWsDTOPopulator"
          class="com.worldpay.worldpayocccommons.populators.HttpRequestPaymentDetailsWsDTOPopulator">
        <constructor-arg name="httpRequestAddressWsDTOPopulator" ref="httpRequestAddressWsDTOPopulator"/>
    </bean>


</beans>
