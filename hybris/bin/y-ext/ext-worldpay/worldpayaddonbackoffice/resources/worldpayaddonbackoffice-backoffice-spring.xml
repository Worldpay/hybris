<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:schemaLocation="http://www.springframework.org/schema/beans
           http://www.springframework.org/schema/beans/spring-beans.xsd">

    <bean id="worldpayaddonbackofficeLabelLocator" class="com.hybris.cockpitng.util.labels.ResourcesLabelLocator"
          init-method="init" lazy-init="false">
        <property name="location" value="/worldpayaddonbackoffice-backoffice-labels/"/>
        <property name="name" value="labels"/>
    </bean>

    <bean id="abstractAmountRenderer" class="com.worldpay.worldpayaddonbackoffice.renderers.AbstractAmountRenderer"
          abstract="true">
        <constructor-arg name="typeFacade" ref="typeFacade"/>
        <constructor-arg name="propertyValueService" ref="propertyValueService"/>
        <constructor-arg name="labelService" ref="labelService"/>
        <constructor-arg name="permissionFacade" ref="permissionFacade"/>
    </bean>

    <alias name="worldpayPaymentTransactionAmountRenderer" alias="paymentTransactionAmountRenderer"/>
    <bean id="worldpayPaymentTransactionAmountRenderer" parent="abstractAmountRenderer"
          class="com.worldpay.worldpayaddonbackoffice.renderers.PaymentTransactionAmountRenderer">
    </bean>

    <alias name="worldpayPaymentTransactionEntryAmountRenderer" alias="paymentTransactionEntryAmountRenderer"/>
    <bean id="worldpayPaymentTransactionEntryAmountRenderer" parent="abstractAmountRenderer"
          class="com.worldpay.worldpayaddonbackoffice.renderers.PaymentTransactionEntryAmountRenderer">
    </bean>

    <bean id="worldpayNullSafeListCellRenderer"
          class="com.worldpay.worldpayaddonbackoffice.renderers.WorldpayNullSafeCellRenderer">
        <constructor-arg name="nestedAttributeUtils" ref="nestedAttributeUtils"/>
        <constructor-arg name="defaultListCellRenderer" ref="defaultListCellRenderer"/>
    </bean>

</beans>
